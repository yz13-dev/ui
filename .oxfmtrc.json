{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "sortImports": {},
  "ignorePatterns": [
    "dist/**",
    ".next/**",
    "coverage/**",
    "build/**",
    ".turbo/**",
    ".cache/**",
    "packages/paykit/src/database/migrations/**",
    "**/*.mdx"
  ]
}
