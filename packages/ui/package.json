  "homepage": "https://github.com/yz13-dev/ui#readme",
  "bugs": {
    "url": "https://github.com/yz13-dev/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "dev": "tsup --watch",
    "lint": "oxlint",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
