{
  "name": "@yz13/ui",
  "version": "0.2.3",
  "description": "A modern React UI component library with Tailwind CSS",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./components/logo/*": "./src/components/logo/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./globals.css": "./src/styles/globals.css"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwindcss",
    "typescript"
  ],
  "author": "YZ13",
  "license": "MIT",
  "repository": {
