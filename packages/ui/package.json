{
  "name": "@yz13/ui",
  "version": "0.2.3",
  "description": "A modern React UI component library with Tailwind CSS",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./components/logo/*": "./src/components/logo/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./styles/globals.css": "./src/styles/globals.css",
    "./icons": "./src/components/icons.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./components/ui/*": "./src/components/ui/*.tsx"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwindcss",
    "typescript"
  ],
  "author": "YZ13",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yz13-dev/ui.git"
  },
  "homepage": "https://github.com/yz13-dev/ui#readme",
  "bugs": {
    "url": "https://github.com/yz13-dev/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "dev": "tsup --watch",
    "lint": "oxlint",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@tailwindcss/cli": "^4.1.11",
    "@types/react": "^19.1.8",
    "gradient-border-plugin": "^1.1.3",
    "open-color": "^1.9.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tailwindcss": "catalog:",
    "tsup": "^8.5.0",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@base-ui-components/react": "^1.0.0-beta.2",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "motion": "^12.23.12",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.77.0",
    "react-phone-number-input": "^3.4.12",
    "react-resizable-panels": "^4.11.2",
    "react-use-measure": "^2.1.7",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.5",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  }
}
