{
  "name": "with-tailwind",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:playground": "bun run dev --filter playground --filter @yz13/ui",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "bunx oxfmt --write \"**/*.{ts,tsx,md}\"",
    "format:check": "bunx oxfmt --write \"**/*.{ts,tsx,md}\""
  },
  "catalog": {
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "^6.0.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/node": "24.10.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "turbo": "^2.5.4",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
